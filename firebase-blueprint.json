{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user in the Walkie-Talkie app",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "isTalking": { "type": "boolean" },
        "target": { "type": "string" },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "isTalking", "target", "lastSeen"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "target": { "type": "string" }
      },
      "required": ["senderId", "senderName", "text", "timestamp", "target"]
    },
    "Signal": {
      "title": "Signal",
      "description": "WebRTC signaling data",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "type": { "type": "string", "enum": ["offer", "answer", "candidate"] },
        "data": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "receiverId", "type", "data", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User presence and info"
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Chat messages"
    },
    "/signals/{signalId}": {
      "schema": { "$ref": "#/entities/Signal" },
      "description": "WebRTC signaling messages"
    }
  }
}
